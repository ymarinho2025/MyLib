{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/api/css/$1" },
    { "src": "/js/(.*)", "dest": "/api/js/$1" },
    { "src": "/img/(.*)", "dest": "/api/img/$1" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*\\.php)", "dest": "/api/$1" }
  ]
}
